@model Urun

<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="gallery-wrap">
                    <div class="img-big-wrap img-thumbnail">
                        <a href="~/img/@Model.Resim" data-type="image" data-fslightbox="mygallery">
                            <img src="~/img/@Model.Resim" alt="">
                        </a>
                    </div>
                    <div class="thumbs-wrap">
                        <a href="~/img/1-big.jpeg" data-type="image" data-fslightbox="mygallery">
                            <img width="60" height="60" src="~/img/1.jpeg" alt="">
                        </a>
                        <a href="~/img/2-big.jpeg" data-type="image" data-fslightbox="mygallery">
                            <img width="60" height="60" src="~/img/2.jpeg" alt="">
                        </a>
                        <a href="~/img/3-big.jpeg" data-type="image" data-fslightbox="mygallery">
                            <img width="60" height="60" src="~/img/3.jpeg" alt="">
                        </a>
                        <a href="~/img/4-big.jpeg" data-type="image" data-fslightbox="mygallery">
                            <img width="60" height="60" src="~/img/4.jpeg" alt="">
                        </a>
                        <a href="~/img/5-big.jpeg" data-type="image" data-fslightbox="mygallery">
                            <img width="60" height="60" src="~/img/5.jpeg" alt="">
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <article>
                    <h4 class="title text-dark">@Model.UrunAdi</h4>
                    <div class="rating-wrap">
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star checked"></span>
                        <span class="fa fa-star "></span>
                    </div>
                    <p class="text-success">Stokta</p>
                    <div class="mb-3">
                        <b class="price h5">@Model.Fiyat ₺</b>
                    </div>
                    <div class="product-desc">
                        <p>@Model.Aciklama</p>
                    </div>
                    <dl class="row border-bottom">
                        <dt class="col-3">Renk:</dt>
                        <dd class="col-9">Yıldız Işığı</dd>
                        <dt class="col-3">Bağlantı Özellikleri:</dt>
                        <dd class="col-9">GPS</dd>
                    </dl>
                    <div class="row mb-4">
                        <div class="col-md-4 col-6 mb-2">
                            <label class="form-label">Kasa Boyutu</label>
                            <select class="form-select">
                                <option value="">41mm</option>
                                <option value="">45mm</option>
                            </select>
                        </div>
                    </div>
                    <div class="buttons">
                        <a href="#" class="btn btn-warning">
                            <i class="fa fa-shopping-basket me-1"></i>
                                Sepete Ekle
                        </a>
                        <a href="#" class="btn btn-light">
                            <i class="fa fa-heart me-1"></i>
                                Beğen
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

@{
    var benzerurunler = (List<Urun>)ViewData["BenzerUrunler"]!;

    if(benzerurunler.Count>0){
        <section class="py-4">
            <div class="container">
                <header class="section-heading">
                    <h4 class="mb-3">Benzer ürünler</h4>
                </header>
                <div class="row gy-3">

                    @foreach(var urun in benzerurunler){

                        <div class="col-lg-3 col-sm-6 col-12">
                            <figure class="card shadow">
                                <div class="img-wrap">
                                    <a href="">
                                        <span class="topbar">
                                            <a href="#" class="float-end">
                                                <i class="fa fa-regular fa-heart fa-lg"></i>
                                            </a>
                                        </span>
                                        <img src="~/img/@urun.Resim" alt="@urun.UrunAdi" class="card-img-top">
                                    </a>
                                </div>
                                <figcaption class="info-wrap border-top">
                                    <a asp-controller="Urun" asp-action="Details" asp-route-id="@urun.Id" class="title text-truncate">@urun.UrunAdi</a>
                                        <div class="price-wrap mb-3">
                                            <strong class="price">@urun.Fiyat ₺</strong>
                                            @* <del class="price-old">9.999 ₺</del> *@
                                        </div>
                                        <a href="" class="btn btn-light w-100">
                                            <i class="fas fa-shopping-basket me-1"></i> Sepete Ekle</a>
                                </figcaption>
                            </figure>
                        </div>
                    }
                    
                </div>
            </div>
        </section>

    }

}