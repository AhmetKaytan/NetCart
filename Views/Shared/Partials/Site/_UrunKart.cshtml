@model Urun
<figure class="card shadow">
    <div class="img-wrap">
        <b class="badge bg-success">İndirim</b>
        <img src="~/img/@Model.Resim" alt="@Model.UrunAdi">
    </div>
    <figcaption class="info-wrap border-top">
        <a href="#" class="float-end btn btn-light btn-icon">
            <i class="fa fa-heart"></i>
        </a>
        <a asp-controller="Urun" asp-action="Details" asp-route-id="@Model.Id" class="title text-truncate">
            @Model.UrunAdi
        </a>
        <div class="price-wrap">
            <span class="price">@Model.Fiyat ₺</span>
            @* <del class="price-old">6.999</del> *@
        </div>
    </figcaption>
</figure>